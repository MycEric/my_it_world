# 通义千问 API Key（从 https://dashscope.console.aliyun.com/ 获取）
# 切勿提交真实 Key 到 Git
DASHSCOPE_API_KEY=your-api-key-here

# 模型名称，默认 qwen-turbo
TONGYI_MODEL=qwen-turbo

# 服务端口
AI_SERVICE_PORT=8090

# MySQL（与 Java 微服务共用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=demo1
MYSQL_DATABASE=myit_world

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# 给 LLM 的滑动窗口（消息条数）
HISTORY_WINDOW=20
